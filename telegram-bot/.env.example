# Token do seu bot no Telegram (obtenha com @BotFather)
TELEGRAM_TOKEN=seu_token_aqui

# Chave da API Groq (gratuita em https://console.groq.com)
GROQ_API_KEY=sua_chave_aqui

# URL do backend do FlightLog (padrão: local)
FLIGHTLOG_URL=http://127.0.0.1:8000

# Seu ID no Telegram (segurança: só você pode usar o bot)
# Para descobrir seu ID, mande /start pro bot e veja o log, ou use @userinfobot
ALLOWED_USER_IDS=seu_id_aqui
