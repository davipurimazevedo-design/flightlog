# ── Frontend (Vercel / local) ─────────────────────────────────────────────────
# Copie para frontend/.env.local e preencha. SEM estas variáveis, a auth fica
# desligada e o app funciona como hoje (útil pra rodar o desktop/dev).

# Projeto Supabase (Settings > API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...        # anon public (pode ser exposta no cliente)

# URL do backend no Render. Em dev/desktop, deixe vazio (usa 127.0.0.1:8000).
VITE_API_URL=https://flightlog-api.onrender.com
