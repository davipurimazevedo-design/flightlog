# ── Backend (Render / local) ──────────────────────────────────────────────────
# Copie para backend/.env e preencha. SEM este arquivo, o backend roda em modo
# local sem auth (SQLite), como o app desktop atual.

# Postgres do Supabase (Settings > Database > Connection string > URI).
# Sem isso, usa SQLite local.
DATABASE_URL=postgresql://postgres:SENHA@db.xxxx.supabase.co:5432/postgres

# Projeto Supabase (Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...            # anon public
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service_role (SECRETO — só no backend)

# OPCIONAL: só valida tokens legados HS256. Os tokens atuais são ES256, verificados
# via JWKS (deriva da SUPABASE_URL). A auth LIGA quando SUPABASE_URL está setada.
# SUPABASE_JWT_SECRET=

# Domínios liberados no CORS (o front na Vercel). Separados por vírgula, sem espaços.
CORS_ORIGINS=https://flightlogbrasil.vercel.app,https://flightlog-five.vercel.app

# Ambiente: "development" (padrão) ou "production". Em produção (setar no Render)
# ativa guardrails: recusa subir sem auth/CORS, esconde /docs, HSTS, rate limit.
# ENVIRONMENT=production

# OPCIONAL — Observabilidade. Se preenchido, o backend inicializa o Sentry (captura
# de erros). Pegue o DSN em sentry.io > seu projeto > Settings > Client Keys (DSN).
# Vazio = desligado. send_default_pii já é False (não envia dados do usuário).
# SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz
